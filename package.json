{
  "name": "ceerem",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc && cp -r drizzle dist/drizzle",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@hono/node-server": "^1.19.14",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "postgres": "^3.4.9",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
